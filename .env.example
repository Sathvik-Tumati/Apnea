
#  .env.example  —  project2/
#  Copy this to .env and fill in your real values.
#  .env is gitignored — .env.example IS committed as documentation.

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI= " "
MONGO_DB=YOUR_DATABASE_NAME

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# ── Model artefacts (optional — defaults to project2/ root) ──────────────────
# MODEL_PATH=apnea_model.keras
# SCALER_PATH=apnea_scaler.pkl
# THRESHOLD=0.60
# OUTPUT_DIR=infer_output
